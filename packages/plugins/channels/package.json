{
	"name": "@euroclaw/channels",
	"version": "0.0.0",
	"type": "module",
	"description": "Channels for euroclaw: the app's own bots via channels() (one shared bot per provider, declared in code), user-registered bots via channelConnections() (credentials in the row, per-tenant), and first-party providers on subpaths.",
	"license": "MIT",
	"author": "Konstantin Ponomarev",
	"homepage": "https://github.com/euroclaw-sh/euroclaw#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/euroclaw-sh/euroclaw.git",
		"directory": "packages/plugins/channels"
	},
	"bugs": {
		"url": "https://github.com/euroclaw-sh/euroclaw/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./connections": {
			"types": "./dist/connections/index.d.ts",
			"import": "./dist/connections/index.js"
		},
		"./telegram": {
			"types": "./dist/telegram/index.d.ts",
			"import": "./dist/telegram/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@euroclaw/contracts": "workspace:*",
		"@euroclaw/storage-core": "workspace:*",
		"@noble/hashes": "2.2.0",
		"arktype": "2.2.0"
	},
	"devDependencies": {
		"@euroclaw/core": "workspace:*",
		"@euroclaw/storage-durable": "workspace:*",
		"ai": "5.0.203",
		"euroclaw": "workspace:*"
	}
}
