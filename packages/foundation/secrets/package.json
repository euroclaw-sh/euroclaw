{
	"name": "@euroclaw/secrets",
	"version": "0.0.0",
	"type": "module",
	"description": "euroclaw's secret resolver: the one door `secrets.get(name)` every subsystem resolves credentials through, the `env()` provider, and the `[env()]` default. Node-free — reads the env GLOBAL, imports no `node:*`, so an edge runtime or a sandbox can apply it.",
	"license": "MIT",
	"author": "Konstantin Ponomarev",
	"homepage": "https://github.com/euroclaw-sh/euroclaw#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/euroclaw-sh/euroclaw.git",
		"directory": "packages/foundation/secrets"
	},
	"bugs": {
		"url": "https://github.com/euroclaw-sh/euroclaw/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "rm -rf dist && tsc",
		"test": "vitest run tests",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@euroclaw/contracts": "workspace:*"
	}
}
