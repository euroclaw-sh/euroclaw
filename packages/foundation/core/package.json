{
	"name": "@euroclaw/core",
	"version": "0.0.0",
	"type": "module",
	"description": "The euroclaw governance & privacy kernel: the redactor, hash-chained audit, approval gate, and createGovernance — the non-bypassable pipeline. Re-exports @euroclaw/contracts.",
	"license": "MIT",
	"author": "Konstantin Ponomarev",
	"homepage": "https://github.com/euroclaw-sh/euroclaw#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/euroclaw-sh/euroclaw.git",
		"directory": "packages/foundation/core"
	},
	"bugs": {
		"url": "https://github.com/euroclaw-sh/euroclaw/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "rm -rf dist && tsc",
		"test": "vitest run tests",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@euroclaw/contracts": "workspace:*",
		"@euroclaw/errors": "workspace:*",
		"@noble/hashes": "2.2.0",
		"arktype": "2.2.0"
	}
}
