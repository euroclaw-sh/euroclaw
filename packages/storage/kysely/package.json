{
	"name": "@euroclaw/storage-kysely",
	"version": "0.0.0",
	"type": "module",
	"description": "Kysely adapter for the @euroclaw/storage-core Adapter port — works with any Kysely SQL dialect. Patterns adapted from Better Auth (MIT).",
	"license": "MIT",
	"author": "Konstantin Ponomarev",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "rm -rf dist && tsc",
		"test": "vitest run src",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@euroclaw/errors": "workspace:*",
		"@euroclaw/storage-core": "workspace:*"
	},
	"peerDependencies": {
		"kysely": ">=0.27.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "7.6.13",
		"better-sqlite3": "12.11.1",
		"kysely": "0.29.2"
	}
}
