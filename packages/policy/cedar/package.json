{
	"name": "@euroclaw/policy-cedar",
	"version": "0.0.0",
	"type": "module",
	"description": "Cedar policy engine for euroclaw: evaluates tool calls against Cedar policies (deny-by-default) with conditional needs-approval. Implements the @euroclaw/contracts PolicyEngine port.",
	"license": "MIT",
	"author": "Konstantin Ponomarev",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "rm -rf dist && tsc",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@cedar-policy/cedar-wasm": "4.11.1",
		"@euroclaw/authz": "workspace:*",
		"@euroclaw/contracts": "workspace:*",
		"arktype": "2.2.0"
	},
	"devDependencies": {
		"@euroclaw/core": "workspace:*"
	}
}
